    "The app ran out of memory. Try closing other apps and try again." : {
      "comment" : "Memory allocation error",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アプリのメモリが不足しました。他のアプリを閉じてから、もう一度お試しください。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "應用程式記憶體不足，請關閉其他應用程式後再試一次。"
          }
        }
      }
    },
    "The device is no longer connected. Please reconnect it and try again." : {
      "comment" : "Device disconnected error",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "デバイスが接続されていません。再接続してから、もう一度お試しください。"
