    },
    "Couldn't connect to the device. Make sure it's unlocked and set to file transfer mode, then try again." : {
      "comment" : "Connecting error",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "デバイスに接続できませんでした。デバイスのロックを解除してファイル転送モードに設定してから、もう一度お試しください。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "無法連線至裝置，請確認裝置已解鎖並設定為檔案傳輸模式，然後再試一次。"
          }
        }
      }
    },
    "Couldn't create the folder. The device may be full or doesn't allow creating folders here." : {
      "comment" : "Create folder error fallback",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "フォルダを作成できませんでした。デバイスの容量が不足しているか、このフォルダの作成が許可されていない可能性があります。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "無法建立資料夾，裝置可能已滿或不允許在此處建立資料夾。"
          }
        }
      }
    },
    "Couldn't delete this item. The file may be in use on the device — please try again." : {
      "comment" : "Delete error fallback",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "この項目を削除できませんでした。ファイルがデバイスで使用中の可能性があります。もう一度お試しください。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "無法刪除此項目，檔案可能正在裝置上使用中，請稍後再試。"
          }
        }
      }
    },
    "Couldn't detect connected devices. Please check the USB connection and try again." : {
      "comment" : "Device detection error fallback",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "接続されているデバイスを検出できませんでした。USB接続を確認してから、もう一度お試しください。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "無法偵測已連接的裝置，請檢查 USB 連線後再試一次。"
          }
        }
      }
    },
    "Couldn't download the file. The device may be busy or disconnected — please try again." : {
      "comment" : "Download error fallback",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ファイルをダウンロードできませんでした。デバイスがビジー状態か切断されている可能性があります。もう一度お試しください。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "無法下載檔案，裝置可能正忙碌或已斷線，請稍後再試。"
          }
        }
      }
    },
    "Couldn't load the folder contents. The device may be busy — please try again." : {
      "comment" : "List folder error fallback",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "フォルダの内容を読み込めませんでした。デバイスがビジー状態の可能性があります。もう一度お試しください。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "無法載入資料夾內容，裝置可能正忙碌中，請稍後再試。"
          }
        }
      }
    },
    "Couldn't rename this item. The device may not support renaming, or the file may be in use." : {
      "comment" : "Rename error fallback",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "この項目の名前を変更できませんでした。デバイスが名前の変更をサポートしていないか、ファイルが使用中の可能性があります。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "無法重新命名此項目，裝置可能不支援重新命名，或檔案正在使用中。"
